rules_version = '2';

// Paste into Firebase console → Firestore Database → Rules.
//
// Model: anonymous auth; a couple doc holds up to two member uids. Everything
// under a couple is readable/writable only by its two members. Couple doc ids
// are unguessable, and invite codes only resolve to a couple id.
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(coupleId) {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    match /couples/{coupleId} {
      // Creating your own space, with yourself as the only member.
      allow create: if request.auth != null
        && request.resource.data.members == [request.auth.uid];

      // Signed-in users may fetch a couple doc by id (ids are random; the
      // joiner needs this read before they become a member).
      allow get: if request.auth != null;
      allow list: if false;

      // Members may edit; a non-member may only add themselves as the second
      // member. Nobody can ever remove the other person.
      allow update: if request.auth != null
        && request.resource.data.members.hasAll(resource.data.members)
        && (
          request.auth.uid in resource.data.members
          || (
            resource.data.members.size() == 1
            && request.resource.data.members.size() == 2
            && request.auth.uid in request.resource.data.members
          )
        );

      allow delete: if false;

      // Status, check-ins, answers, letters — members only.
      match /{collection}/{docId} {
        allow read, write: if isMember(coupleId);
      }
    }

    match /inviteCodes/{code} {
      // You must know the exact code; codes can't be listed or changed.
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['coupleId']);
      allow update, delete: if false;
    }
  }
}
