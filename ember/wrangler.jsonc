// Cloudflare Workers config: serves the exported web build (dist/) as a
// static-assets-only Worker. Used by the dashboard's "import a repository"
// flow — build command `npm run build:web`, deploy `npx wrangler deploy`,
// project path `/ember`.
{
  "name": "ember",
  "compatibility_date": "2026-07-04",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
